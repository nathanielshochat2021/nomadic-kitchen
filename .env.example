# Nomadic Kitchen — environment variables
#
# The quote form (app/api/quote/route.ts) emails new leads via Resend.
# If these are NOT set, the API still works: the lead is logged to the
# server console and the form returns success. Set these in Vercel
# (Project → Settings → Environment Variables) to receive real emails.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Where new quote requests are delivered (your inbox).
QUOTE_TO_EMAIL=hello@nomadickitchen.example

# Verified sender address on your Resend domain.
# e.g. "Nomadic Kitchen <quotes@yourdomain.com>"
QUOTE_FROM_EMAIL=Nomadic Kitchen <quotes@nomadickitchen.example>
